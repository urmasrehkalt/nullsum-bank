# NullSum Bank — Environment Configuration

# Bank identity (set BANK_ADDRESS to your public HTTPS URL before registering)
BANK_NAME=NullSum Bank
BANK_ADDRESS=https://your-vps-domain.com

# Central Bank API base URL
CENTRAL_BANK_URL=https://test.diarainfra.com/central-bank

# Secret key for signing user Bearer tokens (HS256)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# SQLite database file path
DB_PATH=./bank.db

# Keys directory (EC key pair for ES256 inter-bank JWT)
KEYS_DIR=./keys

# Token expiry in days
ACCESS_TOKEN_EXPIRE_DAYS=30

# Local testing: set a fake bank ID to skip central bank registration
# Remove this when deploying to VPS with real central bank URL
# BANK_ID=NLS001
